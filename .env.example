# قاعدة البيانات (PostgreSQL)
DATABASE_URL="postgresql://clinic:clinic@localhost:5432/clinic?schema=public"

# مفتاح تشفير الجلسات (غيّره في الإنتاج) — أنشئ واحداً عبر: openssl rand -base64 32
AUTH_SECRET="change-me-in-production-please-use-a-long-random-string"

# عنوان التطبيق
APP_URL="http://localhost:3000"

# ===== مفاتيح اختيارية (تُستخدم في مراحل لاحقة) =====
# المساعد الذكي (المرحلة 8) — استخدم أحد المزودين
# 1) Anthropic Claude (مفتاح يبدأ بـ sk-ant-...)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=""   # اختياري، افتراضي claude-sonnet-4-6
# 2) Google Gemini (بديل) — مفتاح من Google AI Studio
GEMINI_API_KEY=""
GEMINI_MODEL=""      # اختياري، افتراضي gemini-2.0-flash
# واتساب Cloud API (المرحلة 7)
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""
